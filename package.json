{
  "name": "ponto-max-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter ponto-max-web dev",
    "dev:web": "pnpm --filter ponto-max-web dev",
    "dev:api": "pnpm --filter ponto-max-api dev",
    "build": "pnpm --filter ponto-max-web build",
    "build:web": "pnpm --filter ponto-max-web build",
    "build:api": "pnpm --filter ponto-max-api build",
    "start": "pnpm --filter ponto-max-web start",
    "start:web": "pnpm --filter ponto-max-web start",
    "lint": "pnpm --filter ponto-max-web lint",
    "lint:web": "pnpm --filter ponto-max-web lint",
    "typecheck": "pnpm --filter ponto-max-web typecheck && pnpm --filter ponto-max-api typecheck",
    "typecheck:web": "pnpm --filter ponto-max-web typecheck",
    "typecheck:api": "pnpm --filter ponto-max-api typecheck",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "prisma": "6.16.2"
  },
  "dependencies": {
    "@prisma/client": "6.16.2"
  }
}
