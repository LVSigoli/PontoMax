generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  CLIENT_ADMIN
  MANAGER
  EMPLOYEE
}

enum HolidayType {
  NATIONAL
  STATE
  MUNICIPAL
  COMPANY
}

enum WorkdayStatus {
  OPEN
  CLOSED
  INCONSISTENT
  PENDING_ADJUSTMENT
  ADJUSTED
}

enum TimeEntryKind {
  ENTRY
  EXIT
}

enum TimeEntrySource {
  WEB
  MOBILE
  MANUAL
  ADJUSTMENT
}

enum TimeEntryStatus {
  ACTIVE
  PENDING_REVIEW
  SUPERSEDED
  REJECTED
}

enum AdjustmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum AdjustmentActionType {
  CREATE
  UPDATE
  DELETE
}

enum SessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

model Client {
  id          Int       @id @default(autoincrement())
  name        String    @db.VarChar(120)
  legalName   String?   @map("legal_name") @db.VarChar(160)
  document    String    @unique @db.VarChar(18)
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  companies   Company[]

  @@map("clients")
}

model Company {
  id             Int                 @id @default(autoincrement())
  clientId       Int                 @map("client_id")
  name           String              @db.VarChar(120)
  legalName      String              @map("legal_name") @db.VarChar(160)
  tradeName      String?             @map("trade_name") @db.VarChar(160)
  cnpj           String              @unique @db.VarChar(18)
  timezone       String              @default("America/Sao_Paulo") @db.VarChar(64)
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  users          User[]
  journeys       Journey[]
  holidays       Holiday[]
  workdays       Workday[]
  adjustmentReqs AdjustmentRequest[]
  auditLogs      AuditLog[]

  @@index([clientId], map: "idx_companies_client_id")
  @@map("companies")
}

model User {
  id                         Int                     @id @default(autoincrement())
  companyId                  Int                     @map("company_id")
  employeeCode               String?                 @unique @map("employee_code") @db.VarChar(30)
  fullName                   String                  @map("full_name") @db.VarChar(160)
  email                      String                  @unique @db.VarChar(160)
  cpf                        String                  @unique @db.VarChar(14)
  passwordHash               String                  @map("password_hash") @db.VarChar(255)
  role                       UserRole
  position                   String?                 @db.VarChar(120)
  isActive                   Boolean                 @default(true) @map("is_active")
  lastLoginAt                DateTime?               @map("last_login_at") @db.Timestamptz(6)
  createdAt                  DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company                    Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  journeyAssignments         UserJourneyAssignment[] @relation("UserJourneyAssignments")
  createdJourneyAssignments  UserJourneyAssignment[] @relation("JourneyAssignmentsCreated")
  workdays                   Workday[]
  timeEntries                TimeEntry[]
  requestedAdjustmentReqs    AdjustmentRequest[]     @relation("AdjustmentRequestsRequestedBy")
  reviewedAdjustmentReqs     AdjustmentRequest[]     @relation("AdjustmentRequestsReviewedBy")
  sessions                   AuthSession[]
  passwordResetTokens        PasswordResetToken[]
  auditLogs                  AuditLog[]

  @@index([companyId], map: "idx_users_company_id")
  @@index([companyId, role], map: "idx_users_company_role")
  @@map("users")
}

model Journey {
  id                  Int                     @id @default(autoincrement())
  companyId           Int                     @map("company_id")
  name                String                  @db.VarChar(120)
  description         String?                 @db.VarChar(255)
  scaleCode           String                  @map("scale_code") @db.VarChar(20)
  flexibleSchedule    Boolean                 @default(false) @map("flexible_schedule")
  dailyWorkMinutes    Int                     @map("daily_work_minutes")
  weeklyWorkMinutes   Int?                    @map("weekly_work_minutes")
  expectedEntryTime   DateTime?               @map("expected_entry_time") @db.Time(0)
  expectedExitTime    DateTime?               @map("expected_exit_time") @db.Time(0)
  breakMinutes        Int                     @default(60) @map("break_minutes")
  toleranceMinutes    Int                     @default(10) @map("tolerance_minutes")
  nightShift          Boolean                 @default(false) @map("night_shift")
  isActive            Boolean                 @default(true) @map("is_active")
  createdAt           DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company             Company                 @relation(fields: [companyId], references: [id], onDelete: Restrict)
  userAssignments     UserJourneyAssignment[]

  @@index([companyId], map: "idx_journeys_company_id")
  @@unique([companyId, name], map: "uq_journeys_company_name")
  @@map("journeys")
}

model UserJourneyAssignment {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  journeyId  Int       @map("journey_id")
  createdById Int?     @map("created_by_id")
  validFrom  DateTime  @map("valid_from") @db.Date
  validTo    DateTime? @map("valid_to") @db.Date
  notes      String?   @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation("UserJourneyAssignments", fields: [userId], references: [id], onDelete: Cascade)
  journey    Journey   @relation(fields: [journeyId], references: [id], onDelete: Restrict)
  createdBy  User?     @relation("JourneyAssignmentsCreated", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([journeyId], map: "idx_user_journey_assignments_journey_id")
  @@unique([userId, validFrom], map: "uq_user_journey_assignments_user_start")
  @@map("user_journey_assignments")
}

model Holiday {
  id         Int        @id @default(autoincrement())
  companyId  Int        @map("company_id")
  name       String     @db.VarChar(120)
  date       DateTime   @db.Date
  type       HolidayType
  isActive   Boolean    @default(true) @map("is_active")
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  workdays   Workday[]

  @@unique([companyId, date, name], map: "uq_holidays_company_date_name")
  @@index([companyId, date], map: "idx_holidays_company_date")
  @@map("holidays")
}

model Workday {
  id                    Int                     @id @default(autoincrement())
  companyId             Int                     @map("company_id")
  userId                Int                     @map("user_id")
  holidayId             Int?                    @map("holiday_id")
  date                  DateTime                @db.Date
  status                WorkdayStatus           @default(OPEN)
  scheduledMinutes      Int                     @default(0) @map("scheduled_minutes")
  workedMinutes         Int                     @default(0) @map("worked_minutes")
  overtimeMinutes       Int                     @default(0) @map("overtime_minutes")
  missingMinutes        Int                     @default(0) @map("missing_minutes")
  nightMinutes          Int                     @default(0) @map("night_minutes")
  isHoliday             Boolean                 @default(false) @map("is_holiday")
  createdAt             DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company               Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  holiday               Holiday?                @relation(fields: [holidayId], references: [id], onDelete: SetNull)
  timeEntries           TimeEntry[]
  adjustmentRequests    AdjustmentRequest[]

  @@unique([userId, date], map: "uq_workdays_user_date")
  @@index([companyId, date], map: "idx_workdays_company_date")
  @@index([companyId, status], map: "idx_workdays_company_status")
  @@map("workdays")
}

model TimeEntry {
  id                Int                @id @default(autoincrement())
  workdayId         Int                @map("workday_id")
  userId            Int                @map("user_id")
  kind              TimeEntryKind
  recordedAt        DateTime           @map("recorded_at") @db.Timestamptz(6)
  source            TimeEntrySource    @default(WEB)
  status            TimeEntryStatus    @default(ACTIVE)
  sequence          Int
  timezone          String             @default("America/Sao_Paulo") @db.VarChar(64)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  workday           Workday            @relation(fields: [workdayId], references: [id], onDelete: Cascade)
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointAdjustments  PointAdjustment[]

  @@unique([workdayId, sequence], map: "uq_time_entries_workday_sequence")
  @@index([userId, recordedAt], map: "idx_time_entries_user_recorded_at")
  @@index([workdayId, status], map: "idx_time_entries_workday_status")
  @@map("time_entries")
}

model AdjustmentRequest {
  id               Int                     @id @default(autoincrement())
  companyId        Int                     @map("company_id")
  userId           Int                     @map("user_id")
  workdayId        Int                     @map("workday_id")
  reviewedById     Int?                    @map("reviewed_by_id")
  status           AdjustmentRequestStatus @default(PENDING)
  justification    String                  @db.Text
  reviewNotes      String?                 @map("review_notes") @db.Text
  requestedAt      DateTime                @default(now()) @map("requested_at") @db.Timestamptz(6)
  reviewedAt       DateTime?               @map("reviewed_at") @db.Timestamptz(6)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  company          Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requestedBy      User                    @relation("AdjustmentRequestsRequestedBy", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy       User?                   @relation("AdjustmentRequestsReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  workday          Workday                 @relation(fields: [workdayId], references: [id], onDelete: Cascade)
  pointAdjustments PointAdjustment[]

  @@index([companyId, status], map: "idx_adjustment_requests_company_status")
  @@index([userId, requestedAt], map: "idx_adjustment_requests_user_requested_at")
  @@map("adjustment_requests")
}

model PointAdjustment {
  id                 Int                  @id @default(autoincrement())
  adjustmentRequestId Int                 @map("adjustment_request_id")
  timeEntryId        Int?                 @map("time_entry_id")
  actionType         AdjustmentActionType @map("action_type")
  targetKind         TimeEntryKind        @map("target_kind")
  originalRecordedAt DateTime?            @map("original_recorded_at") @db.Timestamptz(6)
  newRecordedAt      DateTime?            @map("new_recorded_at") @db.Timestamptz(6)
  reason             String?              @db.VarChar(255)
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  adjustmentRequest  AdjustmentRequest    @relation(fields: [adjustmentRequestId], references: [id], onDelete: Cascade)
  timeEntry          TimeEntry?           @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)

  @@index([adjustmentRequestId], map: "idx_point_adjustments_request_id")
  @@map("point_adjustments")
}

model AuthSession {
  id           Int           @id @default(autoincrement())
  userId        Int          @map("user_id")
  refreshToken  String       @unique @map("refresh_token") @db.VarChar(255)
  ipAddress     String?      @map("ip_address") @db.VarChar(64)
  userAgent     String?      @map("user_agent") @db.VarChar(255)
  expiresAt     DateTime     @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime?    @map("revoked_at") @db.Timestamptz(6)
  status        SessionStatus @default(ACTIVE)
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status], map: "idx_auth_sessions_user_status")
  @@map("auth_sessions")
}

model PasswordResetToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt     DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  companyId   Int?     @map("company_id")
  actorUserId Int?     @map("actor_user_id")
  entityType  String   @map("entity_type") @db.VarChar(80)
  entityId    String   @map("entity_id") @db.VarChar(80)
  action      String   @db.VarChar(80)
  metadata    Json?    @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt], map: "idx_audit_logs_company_created_at")
  @@index([actorUserId, createdAt], map: "idx_audit_logs_actor_created_at")
  @@map("audit_logs")
}
