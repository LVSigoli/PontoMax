{
  "name": "ponto-max-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build && node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "db:prepare": "pnpm prisma:generate && pnpm prisma:deploy && pnpm seed:build",
    "prisma:generate": "prisma generate --schema ../../prisma/schema.prisma",
    "prisma:push": "prisma db push --schema ../../prisma/schema.prisma",
    "prisma:validate": "prisma validate --schema ../../prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema ../../prisma/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "seed": "node dist/scripts/seed.js",
    "seed:build": "pnpm build && pnpm seed",
    "smoke": "node dist/scripts/smoke-test.js",
    "smoke:build": "pnpm build && pnpm smoke"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.7.2",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.6",
    "prisma": "^6.16.2",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
